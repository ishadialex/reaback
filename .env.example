# Server Configuration
PORT=4001

# Database
DATABASE_URL="mongodb+srv://username:password@cluster.mongodb.net/database-name"

# Security & Authentication
ADMIN_API_KEY="your-admin-api-key-with-minimum-32-characters"
JWT_SECRET="your-jwt-secret-with-minimum-32-characters"
JWT_REFRESH_SECRET="your-jwt-refresh-secret-with-minimum-32-characters"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Frontend
FRONTEND_URL="http://localhost:3000"

# Optional - Cloudinary (for image uploads)
# Sign up at https://cloudinary.com for free tier
# CLOUDINARY_CLOUD_NAME="your-cloud-name"
# CLOUDINARY_API_KEY="your-api-key"
# CLOUDINARY_API_SECRET="your-api-secret"

# Optional - Email Configuration
# Required for sending verification emails, password resets, etc.
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT=587
# SMTP_SECURE="false"
# SMTP_USER="your-email@gmail.com"
# SMTP_PASS="your-app-password"
# EMAIL_FROM="Alvarado Investment <noreply@alvarado.com>"
# APP_NAME="Alvarado Investment"
# APP_URL="http://localhost:3000"
# ADMIN_EMAIL="admin@alvarado.com"

# Optional - IP Geolocation
# Sign up at https://ipinfo.io for free tier (50k requests/month)
# IPINFO_TOKEN=""

# Optional - Google OAuth
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""
# GOOGLE_CALLBACK_URL="http://localhost:4001/api/auth/google/callback"

# Optional - PDF Access Control
# Comma-separated passcodes (up to 10)
# PDF_ACCESS_PASSCODES="code1,code2,code3"
# PDF_TOKEN_EXPIRY="1h"
